#!/usr/bin/env bash
CONFIG="$HOME/.config/dev-sessions/defaults"
[[ -f "$CONFIG" ]] || exit 0

PANE_PATH=$(tmux display-message -p '#{pane_current_path}' 2>/dev/null)

# Detect repo from ~/worktrees/<repo>/branch or ~/<repo>
REPO=""
if [[ "$PANE_PATH" == "$HOME/worktrees/"*/* ]]; then
  REPO="${PANE_PATH#$HOME/worktrees/}"
  REPO="${REPO%%/*}"
elif [[ "$PANE_PATH" == "$HOME/"* ]]; then
  REPO="${PANE_PATH#$HOME/}"
  REPO="${REPO%%/*}"
fi

DEFAULT=$(grep "^${REPO}=" "$CONFIG" 2>/dev/null | cut -d= -f2 || true)
if [[ -n "$DEFAULT" ]]; then
  echo "base:$DEFAULT"
fi
