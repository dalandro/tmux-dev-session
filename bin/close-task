#!/usr/bin/env bash
set -euo pipefail

TICKET="${1:-}"
SESSION="dev"
WORKTREES_DIR="$HOME/worktrees"

[[ -z "$TICKET" ]] && { echo "Usage: close-task <ticket-id-or-branch>"; exit 1; }

# Sanitize input the same way new-task sanitizes branch names for directories
TICKET_SAFE=$(echo "$TICKET" | tr '/' '-')

WORKTREE_PATH=""
REPO=""
BRANCH_SAFE=""

for repo_dir in "$WORKTREES_DIR"/*/; do
  [[ -d "$repo_dir" ]] || continue
  repo_name=$(basename "$repo_dir")
  for wt in "$repo_dir"*/; do
    [[ -d "$wt" ]] || continue
    dir_name=$(basename "$wt")
    ticket_id=$(echo "$dir_name" | grep -oiE '^[a-z]+-[0-9]+' || echo "$dir_name")
    if [[ "$ticket_id" == "$TICKET_SAFE" ]] || [[ "$dir_name" == "$TICKET_SAFE" ]]; then
      WORKTREE_PATH="$wt"
      REPO="$repo_name"
      BRANCH_SAFE="$dir_name"
      break 2
    fi
  done
done

if [[ -z "$WORKTREE_PATH" ]]; then
  echo "Error: no worktree found for '$TICKET'"
  exit 1
fi

if ! git -C "$WORKTREE_PATH" diff --quiet || ! git -C "$WORKTREE_PATH" diff --cached --quiet; then
  echo "Error: uncommitted changes in $WORKTREE_PATH"
  echo "Commit, stash, or discard changes first."
  exit 1
fi

UNPUSHED=$(git -C "$WORKTREE_PATH" log --oneline "@{u}..HEAD" 2>/dev/null | wc -l || echo "0")
if [[ "$UNPUSHED" -gt 0 ]]; then
  echo "Warning: $UNPUSHED unpushed commit(s) in $WORKTREE_PATH"
  read -rp "Continue anyway? [y/N]: " CONFIRM
  [[ "$CONFIRM" =~ ^[Yy]$ ]] || exit 1
fi

WINDOW_NAME=$(echo "$BRANCH_SAFE" | grep -oiE '^[a-z]+-[0-9]+' || echo "$BRANCH_SAFE")
if tmux list-windows -t "$SESSION" -F "#{window_name}" 2>/dev/null | grep -qxF "$WINDOW_NAME"; then
  tmux kill-window -t "$SESSION:$WINDOW_NAME"
fi

git -C "$HOME/$REPO" worktree remove "$WORKTREE_PATH"

echo "Closed $REPO/$BRANCH_SAFE"
