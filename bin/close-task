#!/usr/bin/env bash
set -euo pipefail

SESSION="${TMUX_DEV_SESSION:-dev}"
WORKTREES_DIR="$HOME/worktrees"

usage() {
  echo "Usage: close-task                  # infer from \$PWD (must be inside a worktree)"
  echo "       close-task <branch>         # match by branch dir name across repos"
  echo "       close-task <repo> <branch>  # explicit"
  exit 1
}

WORKTREE_PATH=""
REPO=""
BRANCH_SAFE=""

if [[ $# -eq 0 ]]; then
  # Infer from current directory: must live under $WORKTREES_DIR/<repo>/<branch>...
  if [[ "$PWD" != "$WORKTREES_DIR/"*/* ]]; then
    echo "Error: not inside a worktree under $WORKTREES_DIR"
    usage
  fi
  REL="${PWD#$WORKTREES_DIR/}"
  REPO="${REL%%/*}"
  REL="${REL#*/}"
  BRANCH_SAFE="${REL%%/*}"
  WORKTREE_PATH="$WORKTREES_DIR/$REPO/$BRANCH_SAFE"
elif [[ $# -eq 1 ]]; then
  TARGET=$(echo "$1" | tr '/' '-')
  for repo_dir in "$WORKTREES_DIR"/*/; do
    [[ -d "$repo_dir" ]] || continue
    candidate="$repo_dir$TARGET"
    if [[ -d "$candidate" ]]; then
      REPO=$(basename "$repo_dir")
      BRANCH_SAFE="$TARGET"
      WORKTREE_PATH="$candidate"
      break
    fi
  done
  if [[ -z "$WORKTREE_PATH" ]]; then
    echo "Error: no worktree found for '$TARGET' under $WORKTREES_DIR"
    exit 1
  fi
elif [[ $# -eq 2 ]]; then
  REPO="$1"
  BRANCH_SAFE=$(echo "$2" | tr '/' '-')
  WORKTREE_PATH="$WORKTREES_DIR/$REPO/$BRANCH_SAFE"
  if [[ ! -d "$WORKTREE_PATH" ]]; then
    echo "Error: worktree not found at $WORKTREE_PATH"
    exit 1
  fi
else
  usage
fi

if [[ -n "$(git -C "$WORKTREE_PATH" status --porcelain)" ]]; then
  echo "Error: uncommitted changes (including untracked files) in $WORKTREE_PATH"
  echo "Commit, stash, or discard changes first."
  exit 1
fi

UNPUSHED=$(git -C "$WORKTREE_PATH" rev-list --count "@{u}..HEAD" 2>/dev/null || echo 0)
if [[ "$UNPUSHED" -gt 0 ]]; then
  echo "Warning: $UNPUSHED unpushed commit(s) in $WORKTREE_PATH"
  read -rp "Continue anyway? [y/N]: " CONFIRM
  [[ "$CONFIRM" =~ ^[Yy]$ ]] || exit 1
fi

# If invoked from inside the worktree itself, cd out before removing.
if [[ "$PWD" == "$WORKTREE_PATH"* ]]; then
  cd "$HOME"
fi

WINDOW_NAME="$BRANCH_SAFE"
if tmux list-windows -t "$SESSION" -F "#{window_name}" 2>/dev/null | grep -qxF "$WINDOW_NAME"; then
  tmux kill-window -t "$SESSION:$WINDOW_NAME"
fi

git -C "$HOME/$REPO" worktree remove "$WORKTREE_PATH"

echo "Closed $REPO/$BRANCH_SAFE"
