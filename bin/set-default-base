#!/usr/bin/env bash
set -euo pipefail

REPO="${1:-}"
BASE="${2:-}"

[[ -z "$REPO" || -z "$BASE" ]] && { echo "Usage: set-default-base <repo> <branch>"; exit 1; }

CONFIG_DIR="$HOME/.config/dev-sessions"
CONFIG_FILE="$CONFIG_DIR/defaults"

mkdir -p "$CONFIG_DIR"
touch "$CONFIG_FILE"

if grep -q "^${REPO}=" "$CONFIG_FILE"; then
  # Portable sed -i (works on GNU and BSD/macOS)
  sed -i.bak "s|^${REPO}=.*|${REPO}=${BASE}|" "$CONFIG_FILE" && rm -f "$CONFIG_FILE.bak"
else
  echo "${REPO}=${BASE}" >> "$CONFIG_FILE"
fi

echo "Default base for $REPO set to: $BASE"
